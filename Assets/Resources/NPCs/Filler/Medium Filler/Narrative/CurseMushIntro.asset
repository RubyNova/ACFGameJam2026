  _characterDialoguePairs:
  - _character: {fileID: 11400000, guid: b10337f2996f8504d927d329f0cc571b, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Hey so. I know you can't see under this cloak.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: b10337f2996f8504d927d329f0cc571b, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: But mushrooms are all over my skin like hives.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: b10337f2996f8504d927d329f0cc571b, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: I think I fell victim to some sort of mushroom-type curse.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: b10337f2996f8504d927d329f0cc571b, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Do you have any hex or curse-be-gone potions? And could you mix that with
      a mushroom?
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  _choices: []
  _isDepartingSequence: 0
  <SourceScript>k__BackingField: 'IGM: Hey so. I know you can''t see under this cloak.


    IGM:
    But mushrooms are all over my skin like hives.


    IGM: I think I fell victim
    to some sort of mushroom-type curse.


    IGM: Do you have any hex or curse-be-gone
    potions? And could you mix that with a mushroom?'
