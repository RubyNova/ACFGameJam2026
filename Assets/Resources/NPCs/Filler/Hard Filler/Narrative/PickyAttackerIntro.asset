  _characterDialoguePairs:
  - _character: {fileID: 11400000, guid: b10337f2996f8504d927d329f0cc571b, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Ugh... I need some attack potions. But I hate the hot taste...
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: b10337f2996f8504d927d329f0cc571b, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Any way you can neutralize that with something? I think there's a neutralizing
      potion...
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: b10337f2996f8504d927d329f0cc571b, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: 'Though usually I know that refers to mood potions... '
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: b10337f2996f8504d927d329f0cc571b, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: So make a neutral mood potion first...?
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  _choices: []
  _isDepartingSequence: 0
  <SourceScript>k__BackingField: "IGM: Ugh... I need some attack potions. But I hate
    the hot taste...\n\nIGM: Any way you can neutralize that with something? I think
    there's a neutralizing potion...\n\nIGM: Though usually I know that refers to
    mood potions... \n\nIGM: So make a neutral mood potion first...?\n\n"
