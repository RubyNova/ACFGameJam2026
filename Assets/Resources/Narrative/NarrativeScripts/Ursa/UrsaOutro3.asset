--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7f8908c837a045e47ac98c38fa85f59d, type: 3}
  m_Name: UrsaOutro3
  m_EditorClassIdentifier: Assembly-CSharp::ACHNarrativeDriver.ScriptableObjects.NarrativeSequence
  _backgroundSprite: {fileID: 0}
  _nextSequence: {fileID: 0}
  _musicFiles: []
  _soundEffectFiles: []
  _characterDialoguePairs:
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "Yes, yes\u2026 this is exactly what we are looking for. Thank you, ever
      so."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "Urgh\u2026 I can\u2019t believe I didn\u2019t see it coming\u2026"
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "What can I do if\u2026 I don\u2019t know what will happen\u2026?"
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "Is nothing certain\u2026?"
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 7279c6ca5ad205d419789771dbd57d5c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "I mean\u2026 um\u2026"
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 7279c6ca5ad205d419789771dbd57d5c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "(Ma\u2019am, this is an apothecary\u2026.????)"
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 7279c6ca5ad205d419789771dbd57d5c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "\u2026I just think that predicting the future is hard."
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 7279c6ca5ad205d419789771dbd57d5c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Some things are just going to happen that are outside your control.
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 7279c6ca5ad205d419789771dbd57d5c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "\u2026a-and that\u2019s hard to accept, believe me."
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 7279c6ca5ad205d419789771dbd57d5c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "Not having a name for days on end will help you to\u2026 accept that."
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 7279c6ca5ad205d419789771dbd57d5c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "\u2026kind of."
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "\u2026I see."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "\u2026I can sense the pain in your words."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Perhaps its childish of me to whine so much.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "Perhaps there are things that can\u2019t be controlled\u2026"
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "\u2026I apologize for troubling you so."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "\u2026I will examine the stars more once Rosa is nursed back to health."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: I will send her back here with my findings.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: I cannot thank you enough for your help.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: May fate be kind to you.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  _choices: []
  <SourceScript>k__BackingField: "Ursa: Yes, yes\u2026 this is exactly what we are
    looking for. Thank you, ever so./d2\r\n\r\nUrsa: Urgh\u2026 I can\u2019t believe
    I didn\u2019t see it coming\u2026/d2\r\n\r\nUrsa: What can I do if\u2026 I don\u2019t
    know what will happen\u2026?/d2\r\n\r\nUrsa: Is nothing certain\u2026?/d2\r\n\r\nNarrator:
    I mean\u2026 um\u2026/d2\r\n\r\nNarrator: (Ma\u2019am, this is an apothecary\u2026.????)/d2\r\n\r\nNarrator:
    \u2026I just think that predicting the future is hard./d2\r\n\r\nNarrator: Some
    things are just going to happen that are outside your control./d2\r\n\r\nNarrator:
    \u2026a-and that\u2019s hard to accept, believe me./d2\r\n\r\nNarrator: Not having
    a name for days on end will help you to\u2026 accept that./d2\r\n\r\nNarrator:
    \u2026kind of./d2\r\n\r\nUrsa: \u2026I see./d2\r\n\r\nUrsa: \u2026I can sense
    the pain in your words./d2\r\n\r\nUrsa: Perhaps its childish of me to whine so
    much./d2\r\n\r\nUrsa: Perhaps there are things that can\u2019t be controlled\u2026/d2\r\n\r\nUrsa:
    \u2026I apologize for troubling you so./d2\r\n\r\nUrsa: \u2026I will examine
    the stars more once Rosa is nursed back to health./d2\r\n\r\nUrsa: I will send
    her back here with my findings./d2\r\n\r\nUrsa: I cannot thank you enough for
    your help./d2\r\n\r\nUrsa: May fate be kind to you./d2\r\n"
