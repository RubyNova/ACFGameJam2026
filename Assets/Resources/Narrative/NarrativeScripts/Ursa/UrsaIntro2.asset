  m_Script: {fileID: 11500000, guid: 7f8908c837a045e47ac98c38fa85f59d, type: 3}
  m_Name: UrsaIntro2
  m_EditorClassIdentifier: Assembly-CSharp::ACHNarrativeDriver.ScriptableObjects.NarrativeSequence
  _backgroundSprite: {fileID: 0}
  _nextSequence: {fileID: 0}
  _musicFiles: []
  _soundEffectFiles: []
  _characterDialoguePairs:
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Good day. It is me once more.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Through divine readings of the stars, I take it my friend Rosa met you
      well? And enjoyed your potions?
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "Hehehe\u2026 I would have asked her myself if she liked them but\u2026"
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "I can be a\u2026 bit shy when it comes to being with her."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "I unfortunately cannot gleam her emotions from the stars\u2026"
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "Sometimes when I try to look into the future its cloudier than I like\u2026"
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: So that's why I need a potion that lets me focus on magical things!
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Please make something mixing both magic and focus if possible!
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  _choices: []
  _isDepartingSequence: 0
  <SourceScript>k__BackingField: "Ursa: Good day. It is me once more.\r\n\r\nUrsa:
    Through divine readings of the stars, I take it my friend Rosa met you well?
    And enjoyed your potions?\r\n\r\nUrsa: Hehehe\u2026 I would have asked her myself
    if she liked them but\u2026\r\n\r\nUrsa: I can be a\u2026 bit shy when it comes
    to being with her.\r\n\r\nUrsa: I unfortunately cannot gleam her emotions from
    the stars\u2026\r\n\r\nUrsa: Sometimes when I try to look into the future its
    cloudier than I like\u2026\r\n\r\nUrsa: So that's why I need a potion that lets
    me focus on magical things!\n\nUrsa: Please make something mixing both magic
    and focus if possible!\r\n"
