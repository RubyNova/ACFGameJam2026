  _characterDialoguePairs:
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Oh my goodness, thank the stars your caravan is still open!
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "Its\u2026 its Rosa. During training, she suddenly collapsed in exhaustion."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "I wish I could have foretold this event\u2026 but it seems her rashness
      in decision making made that unclear to me\u2026"
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "\u2026please. Please, if you have something revitalizing\u2026 not to
      the extent of the potion you made for her, mind you\u2026"
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 018b214c291fad44b8f16c214f264d0c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "Perhaps something more\u2026 natural? If you know what I mean\u2026?"
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  _choices: []
  <SourceScript>k__BackingField: "Ursa: Oh my goodness, thank the stars your caravan
    is still open!/d2\r\n\r\nUrsa: Its\u2026 its Rosa. During training, she suddenly
    collapsed in exhaustion./d2\r\n\r\nUrsa: I wish I could have foretold this event\u2026
    but it seems her rashness in decision making made that unclear to me\u2026/d2\r\n\r\nUrsa:
    \u2026please. Please, if you have something revitalizing\u2026 not to the extent
    of the potion you made for her, mind you\u2026/d2\r\n\r\nUrsa: Perhaps something
    more\u2026 natural? If you know what I mean\u2026?/d2\r\n"
