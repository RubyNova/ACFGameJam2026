  _characterDialoguePairs:
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "That\u2019s\u2026 the end of the day."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "And\u2026 you have enough money to buy your name back."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Wow.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "You didn\u2019t think you\u2019d be able to do it."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "\u2026I mean part of the money you\u2019ve gotten is also going back
      to paying off for this pretty cool caravan."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: 'But regardless. '
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: You did it.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: It feels a bit bittersweet, honestly.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "You met a lot of nice people, but\u2026"
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "At least you\u2019ll be able to go back to your solitude, you suppose."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: ...
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "\u2026time to pack up shop."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
