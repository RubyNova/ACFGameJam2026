  _characterDialoguePairs:
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "\u2026that\u2019s the day."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "\u2026it was nice seeing Plucky again."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: People are coming here more and more.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Word is spreading about how good this place is.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: That might mean that seeing thoughtful customers like him might be harder.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: You might have to actually try to work through the queue to see some friendlier
      faces.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Not to say faces have been UNFRIENDLY. Mostly.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: At least making things for everyone has been somewhat calming.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "Time to rest up\u2026"
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 0
  _choices: []
  _isDepartingSequence: 0
  <SourceScript>k__BackingField: "Narration: \u2026that\u2019s the day.\r\n\r\nNarration:
    \u2026it was nice seeing Plucky again.\r\n\r\nNarration: People are coming here
    more and more.\r\n\r\nNarration: Word is spreading about how good this place
    is.\r\n\r\nNarration: That might mean that seeing thoughtful customers like him
    might be harder.\r\n\r\nNarration: You might have to actually try to work through
    the queue to see some friendlier faces.\r\n\r\nNarration: Not to say faces have
    been UNFRIENDLY. Mostly.\r\n\r\nNarration: At least making things for everyone
    has been somewhat calming.\r\n\r\nNarration: Time to rest up\u2026"
