  _characterDialoguePairs:
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: ...you just fell for the oldest fae trick in the book.
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: They just took your name from you.
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: And they aren't going to give it back without some cash.
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: But its hard to make money in this day and age quick if you aren't an
      adventurer...
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: ...but what do those adventurers need...?
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Right! Potions!
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: You're pretty well known for being the best brewer at any mixer you go
      to.
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Maybe you could run a stand-up apothecary for a week...
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: ...exchange the money to the fae...
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: ...and get your name back!
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Hoodelum Village isn't far and they love potions...
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 0
  - _character: {fileID: 11400000, guid: bb973c0748022e4479b0b0bdec1dd006, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Alright. Lets do this.
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 0
  _choices: []
  _isDepartingSequence: 0
  <SourceScript>k__BackingField: 'Narration: ...you just fell for the oldest fae
    trick in the book.


    Narration: They just took your name from you.


    Narration:
    And they aren''t going to give it back without some cash.


    Narration: But
    its hard to make money in this day and age quick if you aren''t an adventurer...


    Narration:
    ...but what do those adventurers need...?


    Narration: Right! Potions!


    Narration:
    You''re pretty well known for being the best brewer at any mixer you go to.


    Narration:
    Maybe you could run a stand-up apothecary for a week...


    Narration: ...exchange
    the money to the fae...


    Narration: ...and get your name back!


    Narration:
    Hoodelum Village isn''t far and they love potions...


    Narration: Alright.
    Lets do this.'
