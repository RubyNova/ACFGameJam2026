  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7f8908c837a045e47ac98c38fa85f59d, type: 3}
  m_Name: PluckyOutro3
  m_EditorClassIdentifier: Assembly-CSharp::ACHNarrativeDriver.ScriptableObjects.NarrativeSequence
  _backgroundSprite: {fileID: 0}
  _nextSequence: {fileID: 0}
  _musicFiles: []
  _soundEffectFiles: []
  _characterDialoguePairs:
  - _character: {fileID: 11400000, guid: 9386325197a551e4fb73753368901d97, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: 'Thanks. This tastes pretty dang good. '
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 9386325197a551e4fb73753368901d97, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "\u2026I\u2019m sorry to drop all of this on you all of a sudden."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 9386325197a551e4fb73753368901d97, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "I\u2019m sure you already have to deal with a lot of crappy customers,
      haha\u2026"
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 9386325197a551e4fb73753368901d97, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Last thing you need is someone like me making your day worse.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 7279c6ca5ad205d419789771dbd57d5c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "No\u2026 don\u2019t worry."
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 7279c6ca5ad205d419789771dbd57d5c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "You haven\u2019t done anything wrong. I get it."
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 7279c6ca5ad205d419789771dbd57d5c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "I\u2019m\u2026. also worried that the fae just. Aren\u2019t going to
      give my name back."
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 7279c6ca5ad205d419789771dbd57d5c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "And losing something like your adventuring experience or your name or
      anything\u2026"
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 7279c6ca5ad205d419789771dbd57d5c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: Feels rough.
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 7279c6ca5ad205d419789771dbd57d5c, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: But hey. I just hope my potions can offer a bit of comfort.
    _leftCharacterTalking: 1
    _narratorSpeaking: 1
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 9386325197a551e4fb73753368901d97, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "Oh\u2026 um\u2026 thank you."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 9386325197a551e4fb73753368901d97, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: "Genuinely. Sorry, I don\u2019t want to come off as awkward."
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 9386325197a551e4fb73753368901d97, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: I just. Really appreciate hearing that.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 9386325197a551e4fb73753368901d97, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: I mean. At least this bad experience got me to meet you and find your
      potion shop?
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 9386325197a551e4fb73753368901d97, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: So something good came out of it, at least?
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 9386325197a551e4fb73753368901d97, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: But yeah. Definitely expect me to keep being a regular.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 9386325197a551e4fb73753368901d97, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: 'Thank you. So so much. '
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  - _character: {fileID: 11400000, guid: 9386325197a551e4fb73753368901d97, type: 2}
    _characterTwo: {fileID: 0}
    _hasPoseIndex: 0
    _hasSecondCharacterPoseIndex: 0
    _poseIndex: 0
    _poseIndexTwo: 0
    _text: See you around.
    _leftCharacterTalking: 1
    _narratorSpeaking: 0
    _delayBeforeContinuingInSeconds: 2
  _choices: []
  <SourceScript>k__BackingField: "Plucky: Thanks. This tastes pretty dang good. /d2\r\n\r\nPlucky:
    \u2026I\u2019m sorry to drop all of this on you all of a sudden./d2\r\n\r\nPlucky:
    I\u2019m sure you already have to deal with a lot of crappy customers, haha\u2026/d2\r\n\r\nPlucky:
    Last thing you need is someone like me making your day worse./d2\r\n\r\nNarrator:
    No\u2026 don\u2019t worry./d2\r\n\r\nNarrator: You haven\u2019t done anything
    wrong. I get it./d2\r\n\r\nNarrator: I\u2019m\u2026. also worried that the fae
    just. Aren\u2019t going to give my name back./d2\r\n\r\nNarrator: And losing
    something like your adventuring experience or your name or anything\u2026/d2\r\n\r\nNarrator:
    Feels rough./d2\r\n\r\nNarrator: But hey. I just hope my potions can offer a
    bit of comfort./d2\r\n\r\nPlucky: Oh\u2026 um\u2026 thank you./d2\r\n\r\nPlucky:
    Genuinely. Sorry, I don\u2019t want to come off as awkward./d2\r\n\nPlucky: I
    just. Really appreciate hearing that./d2\r\n\r\nPlucky: I mean. At least this
    bad experience got me to meet you and find your potion shop?/d2\r\n\r\nPlucky:
    So something good came out of it, at least?/d2\r\n\r\nPlucky: But yeah. Definitely
    expect me to keep being a regular./d2\r\n\r\nPlucky: Thank you. So so much. /d2\r\n\r\nPlucky:
    See you around./d2\r\n"
